# Copy to .dev.vars for local development if you need local-only overrides.

# OpenLineage backend (optional)
OPENLINEAGE_ENABLED=true
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_ENDPOINT=api/v1/lineage
OPENLINEAGE_NAMESPACE=tf2-ingest
OPENLINEAGE_JOB_NAME=logs_tf_ingest
OPENLINEAGE_DATASET_NAMESPACE=tf2
