# Copy this file to infra/airflow/airflow.env and set values as needed.

# Airflow image pin (stable as of March 26, 2026)
AIRFLOW_BASE_IMAGE=apache/airflow:3.1.8-python3.12

# Airflow UI login
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_WEB_PORT=8080
AIRFLOW_UID=50000

# Trino connection used by Airflow SQL operators
TF2_TRINO_CONN_ID=trino_default
TF2_TRINO_HOST=tf2-trino
TF2_TRINO_PORT=8081
TF2_TRINO_USER=airflow
TF2_TRINO_CATALOG=tf2
TF2_TRINO_SCHEMA=default

# Schedule defaults (cron)
TF2_AIRFLOW_FEATURE_CRON=15 * * * *
TF2_AIRFLOW_ML_CRON=0 4 * * *
TF2_AIRFLOW_E2E_CRON=30 2 * * *
TF2_AIRFLOW_MAINTENANCE_CRON=0 5 * * 0

# Optional defaults for E2E DAG behaviour
TF2_AIRFLOW_RUN_BASELINE_TRAINING_DEFAULT=false
TF2_AIRFLOW_RUN_ICEBERG_MAINTENANCE_DEFAULT=false

# Iceberg maintenance overrides
TF2_MAINTENANCE_RETENTION=14d
TF2_MAINTENANCE_OPTIMIZE_THRESHOLD=256MB
