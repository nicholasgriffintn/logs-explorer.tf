# Marquez/OpenLineage local runtime configuration
OPENLINEAGE_API_PORT=5000
OPENLINEAGE_ADMIN_PORT=5001
OPENLINEAGE_WEB_PORT=3000

# Image pins (from Marquez quickstart defaults)
OPENLINEAGE_MARQUEZ_IMAGE=marquezproject/marquez:0.51.1
OPENLINEAGE_WEB_IMAGE=marquezproject/marquez-web:0.51.1

# Marquez images are amd64-only on some tags.
# Keep linux/amd64 on arm64 hosts unless you switch to a multi-arch image.
OPENLINEAGE_PLATFORM=linux/amd64
