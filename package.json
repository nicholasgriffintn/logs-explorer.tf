{
  "name": "logs-explorer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "vp fmt && vp lint && vp run test -r && vp run build -r",
    "dev": "pnpm --filter @logs-explorer/ingest-service dev",
    "airflow:up": "infra/airflow/scripts/airflow.sh up",
    "airflow:down": "infra/airflow/scripts/airflow.sh down",
    "airflow:status": "infra/airflow/scripts/airflow.sh status",
    "airflow:dags": "infra/airflow/scripts/airflow.sh dags",
    "airflow:trigger:e2e": "infra/airflow/scripts/airflow.sh trigger-e2e",
    "test": "vp run test -r",
    "build": "vp run build -r",
    "prepare": "vp config"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
